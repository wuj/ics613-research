classDiagram
    class Member {
        name
        email
        status
    }
    class MemberProfile {
        displayName
        contactPreference
        neighborhood
    }
    class InviteToken {
        tokenValue
        status
        expiresAt
        usedAt
    }
    class Listing {
        title
        description
        category
        dietaryTags
        allergenTags
        totalQuantity
        remainingQuantity
        pickupWindow
        status
    }
    class Request {
        requestedQuantity
        status
        requestedAt
        handledAt
        queuePosition
    }
    class MessageThread {
        createdAt
    }
    class Message {
        body
        sentAt
    }
    class Notification {
        eventType
        message
        createdAt
        readAt
    }

    Member "1" -- "1" MemberProfile : has
    Member "1" -- "0..*" InviteToken : creates
    InviteToken "1" -- "0..1" Member : registers
    Member "1" -- "0..*" Listing : owns
    Listing "1" -- "0..*" Request : receives in order
    Member "1" -- "0..*" Request : submits
    Request "1" -- "0..1" MessageThread : has
    MessageThread "1" -- "0..*" Message : contains
    Member "1" -- "0..*" Message : sends
    Member "1" -- "0..*" Notification : receives
    Request "1" -- "0..*" Notification : generates
